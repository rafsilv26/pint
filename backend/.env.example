# Copia este ficheiro para backend/.env e preenche os valores reais.
# No Render, define as mesmas variáveis em Dashboard -> Environment.

# Ligação à Base de Dados (Neon)
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>/neondb?sslmode=require

# Servidor
PORT=3000

# Segurança
JWT_SECRET=<TUA_CHAVE_MESTRA_AQUI>

# ------------------------------------------------------------------
# Envio de emails (Gmail via SMTP — smtp.gmail.com:587)
# Sem estas duas variáveis NENHUM email é enviado (submissão, validação,
# aprovação/rejeição, recuperação de password, boas-vindas).
#
# IMPORTANTE: EMAIL_PASS tem de ser uma "App Password" do Google
# (16 letras, sem espaços), criada em:
#   https://myaccount.google.com/apppasswords
# Exige verificação em 2 passos ativa na conta. A password normal
# da conta Google NÃO funciona.
#
# Testa com: node scripts/test-email.js
# ------------------------------------------------------------------
EMAIL_USER=conta@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxx

# URL pública do backend (usada no link "Ver Badge" do email de aprovação)
APP_URL=https://pint-flim.onrender.com

# URL pública do frontend (usada nos links de recuperação de password
# e de login enviados por email). Em produção, usa o domínio do Vercel.
FRONTEND_URL=http://localhost:5173
