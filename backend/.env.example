# Copia este ficheiro para backend/.env e preenche os valores reais.
# No Render, define as mesmas variáveis em Dashboard -> Environment.

# Ligação à Base de Dados (Neon)
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>/neondb?sslmode=require

# Servidor
PORT=3000

# Segurança
JWT_SECRET=<TUA_CHAVE_MESTRA_AQUI>

# ------------------------------------------------------------------
# Envio de emails — API do Brevo (testa com: node scripts/test-email.js)
#
# Porquê Brevo e não Gmail/SMTP: o Render free bloqueia as portas SMTP
# 25/465/587 desde 26/09/2025 (dava sempre "ETIMEDOUT"). A API do Brevo
# vai por HTTPS (443) e funciona. Plano grátis: 300 emails/dia.
#
#   1. Conta em https://www.brevo.com
#   2. Verificar o remetente (EMAIL_USER) em Settings -> Senders
#   3. Gerar chave em Settings -> SMTP & API -> aba "API Keys"
#      (começa por xkeysib- ; a da aba SMTP NÃO serve)
#   4. Definir BREVO_API_KEY aqui / no Render
#
# EMAIL_USER é o remetente que aparece nos emails.
# ------------------------------------------------------------------
EMAIL_USER=conta@gmail.com
BREVO_API_KEY=xkeysib-...

# URL pública do backend (usada no link "Ver Badge" do email de aprovação)
APP_URL=https://pint-flim.onrender.com

# URL pública do frontend (usada nos links de recuperação de password,
# confirmação de email e login enviados por email). Em produção, usa o
# domínio do Vercel.
FRONTEND_URL=http://localhost:5173

# Chave para acionar a verificação de SLA por cron externo:
#   GET /api/sla-check?key=<CRON_SECRET>
# O job interno corre a cada 12h, mas no Render free o serviço adormece;
# um cron externo (ex.: cron-job.org) garante a verificação diária.
CRON_SECRET=<UMA_CHAVE_ALEATORIA>

# Credencial de conta de serviço Firebase, numa única linha JSON. Necessária
# para enviar notificações PUSH (incluindo alertas de SLA) via FCM.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Apenas para testes/ambientes locais onde nao se pretendem os jobs internos.
DISABLE_SLA_JOB=false
DISABLE_EXPIRATION_JOB=false
