# Copia este ficheiro para backend/.env e preenche os valores reais.
# No Render, define as mesmas variáveis em Dashboard -> Environment.

# Ligação à Base de Dados (Neon)
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>/neondb?sslmode=require

# Servidor
PORT=3000

# Segurança
JWT_SECRET=<TUA_CHAVE_MESTRA_AQUI>

# ------------------------------------------------------------------
# Envio de emails — DOIS MODOS (testa com: node scripts/test-email.js)
#
# EMAIL_USER é sempre obrigatório: é o remetente nos dois modos.
#
# MODO 1 — Brevo API (OBRIGATÓRIO em produção no Render free):
#   O Render free bloqueia as portas SMTP 25/465/587 desde 26/09/2025,
#   por isso Gmail/SMTP dá sempre "ETIMEDOUT". A API do Brevo vai por
#   HTTPS (443) e funciona. Plano grátis: 300 emails/dia.
#   1. Cria conta em https://www.brevo.com
#   2. Verifica o remetente (EMAIL_USER) em Settings -> Senders
#   3. Cria uma chave em Settings -> SMTP & API -> API Keys
#   4. Define BREVO_API_KEY aqui / no Render
#
# MODO 2 — SMTP Gmail (só para desenvolvimento local; usado quando
#   BREVO_API_KEY não está definida):
#   EMAIL_PASS tem de ser uma "App Password" do Google (16 letras,
#   SEM espaços), criada em https://myaccount.google.com/apppasswords
#   (exige verificação em 2 passos). A password normal NÃO funciona.
# ------------------------------------------------------------------
EMAIL_USER=conta@gmail.com
BREVO_API_KEY=
EMAIL_PASS=xxxxxxxxxxxxxxxx

# URL pública do backend (usada no link "Ver Badge" do email de aprovação)
APP_URL=https://pint-flim.onrender.com

# URL pública do frontend (usada nos links de recuperação de password
# e de login enviados por email). Em produção, usa o domínio do Vercel.
FRONTEND_URL=http://localhost:5173
